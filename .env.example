# CUVA AI — environment variables
# Copy to .env (local) or set in Vercel → Settings → Environment Variables.

# --- Ask Cuva via xiaomimimo (OpenAI-compatible protocol) ---
XIAOMIMIMO_API_KEY=
XIAOMIMIMO_BASE_URL=https://token-plan-sgp.xiaomimimo.com/v1
CUVA_ASK_MODEL=mimo-v2.5-pro

# --- Database: Supabase ---
# Run supabase/schema.sql in Supabase SQL Editor first.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Platform ---
PUBLIC_BASE=https://www.cuvaai.xyz

# Local dev only
# PORT=5173
